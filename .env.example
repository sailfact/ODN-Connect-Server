# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=vpn
POSTGRES_USER=vpn
POSTGRES_PASSWORD=changeme-db-password
DATABASE_URL=postgresql+asyncpg://vpn:changeme-db-password@postgres:5432/vpn

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=changeme-jwt-secret
JWT_ACCESS_TTL=900        # 15 minutes (seconds)
JWT_REFRESH_TTL=604800    # 7 days (seconds)

# ── WireGuard ─────────────────────────────────────────────────────────────────
WG_INTERFACE=wg0
WG_PORT=51820
WG_SERVER_PUBLIC_IP=YOUR_SERVER_IP_HERE
WG_SUBNET=10.8.0.0/24
WG_DNS=1.1.1.1,1.0.0.1

# ── TLS (for certbot) ─────────────────────────────────────────────────────────
DOMAIN=vpn.example.com
CERTBOT_EMAIL=admin@example.com

# ── ODN Connect integration ───────────────────────────────────────────────────
ODN_CLIENT_SELF_SERVICE=true
ODN_SERVER_NAME=My VPN

# ── OIDC SSO (optional) ───────────────────────────────────────────────────────
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
